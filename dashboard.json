          "id": 5,
          "title": "Популярные статьи с максимальным почасовым приростом",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-postgresql-datasource",
                      "version": "v0",
                      "spec": {
                        "dataset": "portfolio",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "with cte as (\r\n  SELECT article,\r\n  views,\r\n  round((views - views_lag)::numeric / views_lag, 2) as views_diff,\r\n  datetime\r\n  FROM lag_views_table\r\n  where views_lag > 500 \r\n  and views > 500\r\n  and datetime - datetime_lag = interval '1 hour' \r\n  and article != 'Main_Page')\r\n  \r\n  select article, max(views_diff) as growth_Rate\r\n  from cte\r\n  where $__timeFilter(datetime) \r\n  group by article\r\n  order by max(views_diff) desc",
                        "sql": {
